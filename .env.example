# Home Assistant configuration
HA_TIMEZONE=America/Chicago
HA_LATITUDE=0.0
HA_LONGITUDE=0.0
HA_ELEVATION=0
HA_UNIT_SYSTEM=imperial
HA_CURRENCY=USD

# Home Assistant API
HA_URL=http://your-ha-ip:8123
HA_TOKEN=your-long-lived-access-token

# Backup encryption key (from HA emergency kit)
HA_BACKUP_ENCRYPTION_KEY=your-encryption-key

# MQTT broker (optional, for future IoT devices)
# MQTT_HOST=localhost
# MQTT_PORT=1883
# MQTT_USER=
# MQTT_PASSWORD=

# ── Life Admin Tools ──────────────────────────────────────────────────────────
# Anthropic API key — get one at console.anthropic.com
ANTHROPIC_API_KEY=your-anthropic-api-key

# Gmail OAuth2 credentials are stored as a file, not env vars.
# See tools/life-admin/email/gmail_labeler.py for setup instructions.
# credentials.json path (default: tools/life-admin/email/credentials.json)
# GMAIL_CREDENTIALS_PATH=tools/life-admin/email/credentials.json

# Google Photos API (future — for photo organization)
# GOOGLE_PHOTOS_CLIENT_ID=
# GOOGLE_PHOTOS_CLIENT_SECRET=
